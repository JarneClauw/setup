#!/usr/bin/env bash

RESET="\e[0m"
ERROR="\e[1;31m"
MESSAGE="\e[1;34m"

print() {
  echo -e "${MESSAGE}$1${RESET}"
}

error() {
  echo -e "${ERROR}$1${RESET}"
}

print "Setting up the development environment"

### ALACRITTY ###
print "Setup Alacritty"
dir=$HOME/.config/alacritty
rm -rf $dir; mkdir -p $dir
stow -t $dir alacritty

### GIT ###
print "Setup Git"
dir=$HOME/.config/git
rm -rf $dir; mkdir -p $dir
stow -t $dir git

